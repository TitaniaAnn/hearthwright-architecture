# Reference Control Plane — environment. Copy to .env.local and fill in.
# For local Supabase values run:  supabase status -o env

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret for the on-demand revalidation endpoint (/api/revalidate).
REVALIDATE_SECRET=

# ── Observability ───────────────────────────────────────────────────────────
# Optional. When set, logError() (src/lib/observability.ts) POSTs each handled
# error here for active alerting, in addition to the stderr log. Best-effort and
# non-blocking; repeated identical alerts are coalesced. Accepts a Slack incoming
# webhook (uses the `text` field) or any endpoint that takes a JSON body. Unset =
# stderr logging only. The ingestion edge functions read the same var and fan out
# their 5xx too — set it for edge with `supabase secrets set ERROR_WEBHOOK_URL=...`.
ERROR_WEBHOOK_URL=

# ── OAuth buttons (login UI) ────────────────────────────────────────────────
# The provider must also be enabled in supabase/config.toml with creds in
# supabase/.env (gitignored).
NEXT_PUBLIC_OAUTH_GITHUB=false
NEXT_PUBLIC_OAUTH_GOOGLE=false
